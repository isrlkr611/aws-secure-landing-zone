# Copy to .env for local dev. In production these come from AWS Secrets
# Manager via the External Secrets Operator (see platform/k8s/), never from
# a committed file.

DATABASE_URL=sqlite:///./attack_surface.db

VERIFICATION_TXT_PREFIX=_platform-verify

HIBP_API_KEY=
HIBP_BASE_URL=https://haveibeenpwned.com/api/v3

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@example.com
SLACK_WEBHOOK_URL=

SUBFINDER_BINARY=subfinder
NMAP_BINARY=nmap
NMAP_MAX_RATE=100
SCAN_COMMON_PORTS=21,22,25,80,110,143,443,445,3306,3389,5432,6379,8080,8443,9200,27017

SCAN_INTERVAL_HOURS=24
